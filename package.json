{
  "name": "teahole",
  "version": "0.1.0",
  "description": "茶园树洞 — login-gated but unlinkable discussion platform with rotating posting tokens",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "typecheck": "tsc --noEmit",
    "syntax-check": "node -c server.js && node -c db.js && node -c public/app.js && node -c public/theme-init.js",
    "check": "npm run syntax-check && npm run typecheck",
    "prepare": "git config --local core.hooksPath .githooks || true"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^11.3.0",
    "cookie-parser": "^1.4.6",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "sharp": "^0.34.5"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "typescript": "^6.0.3"
  }
}
